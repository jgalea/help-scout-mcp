{
  "name": "@jgalea/help-scout-mcp",
  "version": "2.4.4",
  "private": true,
  "description": "Help Scout MCP server (security-hardened private fork): search conversations, fetch transcripts, browse docs, and pull reports — all from Claude or any MCP client",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "help-scout-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "security": "semgrep --config .semgrep.yml .",
    "security:ci": "semgrep ci",
    "test": "jest",
    "test:docker": "node test-docker.cjs",
    "test:docker:ci": "node test-docker-ci.cjs",
    "clean": "rimraf dist",
    "version:patch": "node scripts/bump-version.cjs patch",
    "version:minor": "node scripts/bump-version.cjs minor",
    "version:major": "node scripts/bump-version.cjs major",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "prepack": "npm run build",
    "install-hooks": "bash scripts/install-hooks.sh",
    "mcpb:build": "node scripts/build-mcpb.js",
    "mcpb:pack": "npm run mcpb:build && cd helpscout-mcp-extension && npx @anthropic-ai/mcpb pack",
    "build:all": "npm run build && npm run mcpb:build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "mcp-server",
    "help-scout",
    "help-scout-api",
    "helpscout",
    "help scout",
    "customer-support",
    "typescript",
    "nodejs"
  ],
  "author": {
    "name": "Jean Galea",
    "url": "https://github.com/jgalea"
  },
  "contributors": [
    {
      "name": "Drew Burchfield",
      "url": "https://github.com/drewburchfield",
      "comment": "Original author of help-scout-mcp-server"
    },
    {
      "name": "Zack Katz",
      "url": "https://github.com/zackkatz",
      "comment": "Maintainer of GravityKit/help-scout-mcp fork"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgalea/help-scout-mcp.git"
  },
  "homepage": "https://github.com/jgalea/help-scout-mcp#readme",
  "bugs": {
    "url": "https://github.com/jgalea/help-scout-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.15.2",
    "dotenv": "^16.3.1",
    "form-data": "^4.0.5",
    "lru-cache": "^10.1.0",
    "sanitize-html": "^2.17.3",
    "turndown": "^7.2.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.0.1",
    "@types/jest": "^29.5.8",
    "@types/nock": "^10.0.3",
    "@types/node": "^20.10.4",
    "@types/sanitize-html": "^2.16.1",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "nock": "^14.0.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "cross-spawn": "^7.0.6",
    "brace-expansion": "^2.0.2"
  }
}
